// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  FREELANCER
  ENTREPRENEUR
  COLLABORATOR
}

enum PlanType {
  FREE
  PRO
  BUSINESS
  PREMIUM_ENTREPRENEUR
  PREMIUM_FREELANCER
  PREMIUM_INCUBATEUR
}

enum EventCategory {
  NETWORKING
  STARTUP
  INVESTISSEMENT
  FORMATION
  INCUBATEUR
}

enum EventType {
  PHYSICAL
  VIRTUAL
}

enum RegistrationStatus {
  REGISTERED
  WAITLISTED
  CANCELLED
  ATTENDED
}

enum InvitationStatus {
  PENDING
  SENT
  ACCEPTED
  EXPIRED
}

enum InviteMethod {
  EMAIL
  SMS
}

enum AdType {
  COMPANY
  EVENT
  SERVICE
}

enum AdPlacement {
  FEED
  SIDEBAR
  TOP
}

enum PlanStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
}

enum PaymentProvider {
  STRIPE
  WISE
}

model User {
  id                   String               @id @default(uuid())
  email                String               @unique
  password             String
  firstName            String
  lastName             String
  avatarUrl            String?
  role                 UserRole             @default(FREELANCER)
  isEmailVerified           Boolean    @default(false)
  emailVerificationToken    String?
  emailVerificationExpires  DateTime?
  passwordResetToken        String?
  passwordResetExpires      DateTime?
  birthDate            DateTime?
  plan                 PlanType             @default(FREE)
  lastActiveAt         DateTime             @default(now())
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  // Subscription
  subscription         Subscription?

  // Profile relations
  freelancerProfile    FreelancerProfile?
  entrepreneurProfile  EntrepreneurProfile?

  // Messenger relations
  conversations        ConversationParticipant[]
  messages             Message[]

  // Other relations
  notifications        Notification[]
  incubatorPosts       IncubatorPost[]
  uploadedFiles        File[]
  incubatorComments    IncubatorComment[]
  incubatorLikes       IncubatorLike[]
  feedPosts            FeedPost[]
  feedPostLikes        FeedPostLike[]
  feedPostComments     FeedPostComment[]
  savedPosts           SavedPost[]
  
  // Connection relations
  sentRequests         ConnectionRequest[]  @relation("SentRequests")
  receivedRequests     ConnectionRequest[]  @relation("ReceivedRequests")
  relations            UserRelation[]       @relation("UserRelations")
  friendRelations      UserRelation[]       @relation("FriendRelations")

  // New feature relations
  organizedEvents      Event[]                  @relation("OrganizedEvents")
  eventRegistrations   EventRegistration[]      @relation("EventRegistrations")
  sentInvitations      BusinessCardInvitation[] @relation("SentInvitations")
  referralCode         ReferralCode?            @relation("ReferralCode")
  referredBy           Referral?                @relation("ReferredByUser")
  advertisements       Advertisement[]          @relation("Advertisements")
}

model FreelancerProfile {
  id           String               @id @default(uuid())
  userId       String               @unique
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String?
  bio          String?
  skills       String[]
  portfolioUrl String?
  cvUrl        String?
  isAvailable  Boolean              @default(true)
  hourlyRate   Float?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  applications ProjectApplication[]
}

model EntrepreneurProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String?
  website     String?
  bio         String?
  projects    Project[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum ProjectStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Project {
  id            String              @id @default(uuid())
  title         String
  description   String
  budget        Float?
  skills        String[]
  status        ProjectStatus       @default(OPEN)
  ownerId       String
  owner         EntrepreneurProfile @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  applications  ProjectApplication[]
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model ProjectApplication {
  id           String            @id @default(uuid())
  projectId    String
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  freelancerId String
  freelancer   FreelancerProfile @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  coverLetter  String?
  status       ApplicationStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model Conversation {
  id           String                    @id @default(uuid())
  name         String?                   // Group chat name, null for private direct message
  isGroup      Boolean                   @default(false)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  attachments    File[]
  createdAt      DateTime     @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  type      String   // e.g. "MESSAGE", "PROJECT_APPLICATION", "SYSTEM"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model IncubatorPost {
  id        String             @id @default(uuid())
  title     String
  content   String
  category  String             // e.g. "Idea Validation", "Mentorship", "Collaboration"
  authorId  String
  author    User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  IncubatorComment[]
  likes     IncubatorLike[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model IncubatorComment {
  id        String        @id @default(uuid())
  postId    String
  post      IncubatorPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime      @default(now())
}

model IncubatorLike {
  id        String        @id @default(uuid())
  postId    String
  post      IncubatorPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model File {
  id         String   @id @default(uuid())
  name       String
  path       String
  mimeType   String
  size       Int
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId  String?
  message    Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
}

model FeedPost {
  id        String            @id @default(uuid())
  content   String
  imageUrl  String?
  authorId  String
  author    User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     FeedPostLike[]
  comments  FeedPostComment[]
  savedBy   SavedPost[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model SavedPost {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model FeedPostLike {
  id        String   @id @default(uuid())
  postId    String
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model FeedPostComment {
  id        String   @id @default(uuid())
  postId    String
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
}

enum RequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model ConnectionRequest {
  id          String        @id @default(uuid())
  senderId    String
  sender      User          @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User          @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  status      RequestStatus @default(PENDING)
  message     String?
  isCoffee    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([senderId, receiverId])
}

model UserRelation {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("UserRelations", fields: [userId], references: [id], onDelete: Cascade)
  friendId    String
  friend      User     @relation("FriendRelations", fields: [friendId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([userId, friendId])
}

model Subscription {
  id                String          @id @default(uuid())
  userId            String          @unique
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              PlanType        @default(FREE)
  status            PlanStatus      @default(ACTIVE)
  paymentProvider   PaymentProvider @default(STRIPE)
  stripeCustomerId  String?
  stripeSubId       String?
  wiseReference     String?
  pendingAmount     Float?
  pendingCurrency   String?
  pendingPlan       PlanType?
  pendingInterval   String?
  lastPaymentDate   DateTime?
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean         @default(false)
  trialEndsAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

// ─── Events ────────────────────────────────────────────────────────────

model Event {
  id            String              @id @default(uuid())
  title         String
  description   String
  category      EventCategory
  type          EventType
  startDate     DateTime
  endDate       DateTime
  location      String?
  virtualLink   String?
  capacity      Int?
  price         Float               @default(0)
  isFree        Boolean             @default(true)
  imageUrl      String?
  organizerId   String
  organizer     User                @relation("OrganizedEvents", fields: [organizerId], references: [id])
  registrations EventRegistration[]
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model EventRegistration {
  id         String             @id @default(uuid())
  eventId    String
  event      Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId     String
  user       User               @relation("EventRegistrations", fields: [userId], references: [id])
  ticketCode String             @unique @default(uuid())
  status     RegistrationStatus @default(REGISTERED)
  createdAt  DateTime           @default(now())

  @@unique([eventId, userId])
}

// ─── Business Card Invitations ─────────────────────────────────────────

model BusinessCardInvitation {
  id           String           @id @default(uuid())
  senderId     String
  sender       User             @relation("SentInvitations", fields: [senderId], references: [id])
  name         String
  email        String?
  phone        String?
  company      String?
  position     String?
  status       InvitationStatus @default(PENDING)
  inviteMethod InviteMethod
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

// ─── Referral ──────────────────────────────────────────────────────────

model ReferralCode {
  id             String     @id @default(uuid())
  userId         String     @unique
  user           User       @relation("ReferralCode", fields: [userId], references: [id])
  code           String     @unique
  totalReferrals Int        @default(0)
  referrals      Referral[]
  createdAt      DateTime   @default(now())
}

model Referral {
  id             String       @id @default(uuid())
  referralCodeId String
  referralCode   ReferralCode @relation(fields: [referralCodeId], references: [id])
  referredUserId String       @unique
  referredUser   User         @relation("ReferredByUser", fields: [referredUserId], references: [id])
  createdAt      DateTime     @default(now())
}

// ─── Advertisements ────────────────────────────────────────────────────

model Advertisement {
  id           String      @id @default(uuid())
  title        String
  description  String?
  imageUrl     String?
  targetUrl    String?
  type         AdType
  placement    AdPlacement
  advertiserId String
  advertiser   User        @relation("Advertisements", fields: [advertiserId], references: [id])
  impressions  Int         @default(0)
  clicks       Int         @default(0)
  budget       Float?
  isActive     Boolean     @default(true)
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}
